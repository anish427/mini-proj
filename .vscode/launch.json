{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Flask app (deepfake)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "FLASK_DEBUG": "0",
        "PORT": "5000"
      }
    }
  ]
}
