{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/profile", "destination": "/profile.html" },
    { "source": "/static/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    }
  ]
}
